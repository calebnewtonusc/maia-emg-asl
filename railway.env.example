# ---- Authentication ----
# Comma-separated list of valid API keys for the inference server
MAIA_API_KEYS=your-secret-key-here,another-key

# Set to "true" to disable auth (development only!)
MAIA_DISABLE_AUTH=false

# ---- Model artifact (Cloudflare R2) ----
# Public R2 URL for the latest ONNX model — downloaded at startup
R2_MODEL_URL=https://pub-XXXXXXXXXXXX.r2.dev/maia-emg-asl/latest/asl_emg_classifier.onnx

# Local path where model will be stored after download
ONNX_MODEL_PATH=models/asl_emg_classifier.onnx

# ---- Optional: Weights & Biases ----
WANDB_API_KEY=

# ---- Logging ----
LOG_LEVEL=INFO

# ---- ONNX Runtime ----
ORT_NUM_THREADS=2
