# MAIA Mobile App Configuration
# Copy this to .env and fill in your values

# ---- Server Connection ----
# Your Railway deployment URL (from: railway status)
EXPO_PUBLIC_RAILWAY_URL=https://maia-emg-asl-production.up.railway.app

# Primary server URL (set this to Railway URL for production)
EXPO_PUBLIC_SERVER_URL=https://maia-emg-asl-production.up.railway.app

# API key (must match MAIA_API_KEYS on server)
EXPO_PUBLIC_API_KEY=your-api-key-here

# ---- BLE Device ----
EXPO_PUBLIC_BLE_DEVICE_NAME=MAIA-Band

# ---- Inference Mode ----
# true = only use on-device ONNX model (no network required)
# false = try on-device first, fall back to Railway server
EXPO_PUBLIC_FALLBACK_TO_SERVER=true

# ---- Debug ----
EXPO_PUBLIC_DEBUG_EMG=false
